generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           String   @id
  shopId       String?
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  Shop Shop? @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model Booking {
  id            String        @id
  shopId        String
  staffId       String
  serviceId     String
  ref           String        @unique
  status        BookingStatus @default(BOOKED)
  startTime     DateTime
  endTime       DateTime
  customerName  String
  customerPhone String
  cancelledAt   DateTime?
  cancelReason  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  Service       Service       @relation(fields: [serviceId], references: [id])
  Shop          Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  Staff         Staff         @relation(fields: [staffId], references: [id])

  @@index([serviceId])
  @@index([shopId])
  @@index([staffId])
  @@index([startTime])
  @@index([status])
}

model Service {
  id              String    @id
  shopId          String
  name            String
  durationMinutes Int
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  Booking         Booking[]
  Shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model Shop {
  id            String    @id
  name          String
  timezone      String    @default("Europe/London")
  openTime      String    @default("09:00")
  closeTime     String    @default("21:00")
  slotInterval  Int       @default(15)
  leadTime      Int       @default(60)
  bookAheadDays Int       @default(30)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  Admin         Admin[]
  Booking       Booking[]
  Service       Service[]
  Staff         Staff[]
}

model Staff {
  id        String    @id
  shopId    String
  firstName String
  lastName  String
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime
  Booking   Booking[]
  Shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shifts    Shift[]

  @@index([shopId])
}

model Shift {
  id         String   @id
  staffId    String
  day        String
  startTime  String
  endTime    String
  breakStart String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  Staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

enum BookingStatus {
  BOOKED
  CANCELLED
}
